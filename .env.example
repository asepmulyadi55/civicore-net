# Copy to .env and fill in. .env is gitignored — never commit real values.
#
#   cp .env.example .env
#
# See docs/encryption-key-migration.md before setting ENCRYPTION_KEY on an existing
# database: changing it without running the migration leaves stored data unreadable.

# Encrypts Householder.FamilyCardNumber (Nomor KK) at rest.
# Must be EXACTLY 32 characters — shorter values are silently padded (weaker than they
# look), longer values are silently truncated.
#
# Generate (PowerShell):
#   -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_})
# Generate (bash):
#   LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 32; echo
ENCRYPTION_KEY=

# Only needed when rotating to a NEW key later. Leave unset for the first migration:
# it defaults to the old built-in fallback, which is what existing rows are encrypted
# with today.
# ENCRYPTION_OLD_KEY=
